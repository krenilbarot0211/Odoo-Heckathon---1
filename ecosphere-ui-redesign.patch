+def _department_leaderboard(csr_activities: list[CSRActivity]) -> list[dict]:
+    department_counts: dict[str, int] = {}
+    for activity in csr_activities:
+        department_counts[activity.organizer] = department_counts.get(activity.organizer, 0) + 1
+
+    return [
+        {"name": name, "score": min(100, 40 + count * 15)}
+        for name, count in sorted(department_counts.items(), key=lambda kv: kv[1], reverse=True)
+    ] or [{"name": "No CSR activity yet", "score": 0}]
+
+
+def get_gamification_summary(db: Session) -> dict:
+    """Derive XP, level, badges, challenges, and leaderboard from real ESG activity."""
+    carbon_logs = db.query(CarbonLog).all()
+    csr_activities = db.query(CSRActivity).all()
+    policies = db.query(Policy).all()
+    active_policies = [p for p in policies if p.status == "active"]
+
+    carbon_count = len(carbon_logs)
+    csr_count = len(csr_activities)
+    policy_count = len(active_policies)
+
+    xp = carbon_count * 10 + csr_count * 25 + policy_count * 40
+    xp_per_level = 150
+    level = xp // xp_per_level + 1
+    xp_into_level = xp % xp_per_level
+
+    badges = [
+        {
+            "name": "ESG Rookie",
+            "icon": "🌱",
+            "description": "Logged your first ESG action",
+            "unlocked": xp > 0,
+        },
+        {
+            "name": "Carbon Tracker",
+            "icon": "📉",
+            "description": "Logged 5+ carbon entries",
+            "unlocked": carbon_count >= 5,
+            "progress": min(100, round(carbon_count / 5 * 100)),
+        },
+        {
+            "name": "Community Champion",
+            "icon": "🤝",
+            "description": "Ran 3+ CSR activities",
+            "unlocked": csr_count >= 3,
+            "progress": min(100, round(csr_count / 3 * 100)),
+        },
+        {
+            "name": "Policy Guardian",
+            "icon": "🛡",
+            "description": "Published 2+ active policies",
+            "unlocked": policy_count >= 2,
+            "progress": min(100, round(policy_count / 2 * 100)),
+        },
+    ]
+
+    challenges = [
+        {
+            "name": "Zero Waste Week",
+            "icon": "🌳",
+            "description": "Log carbon data every day this week",
+            "progress": min(100, carbon_count * 15),
+            "reward_xp": 100,
+        },
+        {
+            "name": "Volunteer Sprint",
+            "icon": "🩸",
+            "description": "Organize or join 3 CSR activities",
+            "progress": min(100, round(csr_count / 3 * 100)),
+            "reward_xp": 150,
+        },
+        {
+            "name": "Compliance Streak",
+            "icon": "🏛",
+            "description": "Keep all policies active and up to date",
+            "progress": min(100, round((policy_count / len(policies)) * 100)) if policies else 0,
+            "reward_xp": 120,
+        },
+    ]
+
+    return {
+        "xp": xp,
+        "level": level,
+        "xp_into_level": xp_into_level,
+        "xp_per_level": xp_per_level,
+        "badges": badges,
+        "challenges": challenges,
+        "leaderboard": _department_leaderboard(csr_activities),
+    }
+
